# =============================================================================
# Operations Layer Environment Variables
# =============================================================================
# Copy this file to ops.env and fill in your values:
#   cp ops.env.example ops.env
#
# ops.env is NOT checked into git (listed in .gitignore).

# --- Google Cloud / Vertex AI (required for RCA agents v3/v4) ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=northamerica-northeast1
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# --- Anthropic (optional, for RCA agent v1.5 with Claude) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Neo4j Ontology Database ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=ontology
NEO4J_URI=bolt://ontology:7687

# --- GUI ---
GUI_PORT=8073
# HOST_REPO_PATH is set automatically by start-ops.sh — do not edit.
# It ensures Docker paths resolve correctly when running compose from inside the GUI container.
# HOST_REPO_PATH=/home/user/agentic-network-ops
